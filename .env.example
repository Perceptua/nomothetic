# nomon Environment Variables
# Copy this file to .env and fill in values.
# .env is gitignored — never commit secrets.

# =============================================================================
# API Server
# =============================================================================

# Bind address for the REST API server
# Use 127.0.0.1 for local-only, 0.0.0.0 for all interfaces (LAN/Tailscale)
NOMON_API_HOST=0.0.0.0

# Port for the HTTPS REST API
NOMON_API_PORT=8443

# Directory for TLS certificates (auto-generated self-signed on first run)
# NOMON_CERT_DIR=.certs

# =============================================================================
# Camera
# =============================================================================

# Default camera index (0 for first/only camera)
# NOMON_CAMERA_INDEX=0

# Default video resolution
# NOMON_CAMERA_WIDTH=1280
# NOMON_CAMERA_HEIGHT=720

# Default frame rate
# NOMON_CAMERA_FPS=30

# Default video encoder: h264 or mjpeg
# NOMON_CAMERA_ENCODER=h264

# Directory for captured images and recorded videos
# NOMON_CAMERA_DIRECTORY=/home/pi/nomon-media

# =============================================================================
# Stream Server (local LAN only)
# =============================================================================

# NOMON_STREAM_HOST=localhost
# NOMON_STREAM_PORT=8000

# =============================================================================
# Device Identity (Phase 4 — MQTT Telemetry)
# =============================================================================

# Unique identifier for this Pi node in the fleet
# Defaults to Pi serial number if not set
# NOMON_DEVICE_ID=pi-node-01

# =============================================================================
# MQTT (Phase 4 — Telemetry)
# =============================================================================

# MQTT broker address (management server)
# NOMON_MQTT_BROKER=
# NOMON_MQTT_PORT=1883
# NOMON_MQTT_TOPIC=nomon/telemetry
# Interval (in seconds) between telemetry publishes
# NOMON_MQTT_INTERVAL=30

# MQTT credentials (if broker requires auth)
# NOMON_MQTT_USERNAME=
# NOMON_MQTT_PASSWORD=

# =============================================================================
# Authentication (Phase 2.5 — if implemented)
# =============================================================================

# Secret key for JWT token signing — generate with: openssl rand -hex 32
# NOMON_JWT_SECRET=

# Token expiry in seconds (default: 3600 = 1 hour)
# NOMON_JWT_EXPIRY=3600

# Comma-separated list of allowed API keys
# NOMON_API_KEYS=
